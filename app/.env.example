# Положи `.env` рядом с cwd (или задай env в docker-compose).
#
# Как на уроке — отдельные поля (если заданы, они важнее DATABASE_URL для SQLAlchemy):
# DB_HOST=database
# DB_PORT=5432
# DB_USER=safetalk
# DB_PASS=safetalk
# DB_NAME=safetalk
#
# Локально без Postgres: DATABASE_URL не указывать → sqlite:///./app.db
#
# Docker одной строкой:
DATABASE_URL=postgresql://safetalk:safetalk@database:5432/safetalk

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
