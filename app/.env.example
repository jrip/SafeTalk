# Как на уроке: положи копию в каталог, откуда запускаешь uvicorn (имя файла `.env` в корне репозитория).
# В Docker Compose переменные часто задаются через `env_file` / environment — тоже ок, pydantic читает env.

# Copy to `.env` in repo root (or next to your cwd) and adjust.

# Вариант как на уроке — отдельные поля (либо они, либо DATABASE_URL):
# DB_HOST=database
# DB_PORT=5432
# DB_USER=safetalk
# DB_PASS=safetalk
# DB_NAME=safetalk

# Один URL (удобно в Docker):
DATABASE_URL=postgresql://safetalk:safetalk@database:5432/safetalk

# С хоста в Postgres из compose:
# DATABASE_URL=postgresql://safetalk:safetalk@127.0.0.1:5432/safetalk

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
